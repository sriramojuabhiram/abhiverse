/*  ── OLD IMPORTS & CHARACTER CODE (commented out) ─────────────────────────

import { useEffect, useMemo, useRef } from 'react'
import { useFrame, useThree } from '@react-three/fiber'
import { ContactShadows, Sparkles, Text, useGLTF, useTexture, useAnimations } from '@react-three/drei'
import * as THREE from 'three'
import { SkeletonUtils } from 'three-stdlib'
import type { GLTF } from 'three-stdlib'
import { useAppStore } from '../../store/appStore'

type AstronautGLTF = GLTF & {
  scene: THREE.Group
  animations: THREE.AnimationClip[]
}


// ─────────────────────────────────────────────────────────────────────────────
// Typing hands — astronaut gloves resting on the laptop keyboard
// No forearm stubs — just rounded gloves with animated finger tapping.
// ─────────────────────────────────────────────────────────────────────────────
function TypingHands() {
  const leftRef = useRef<THREE.Group>(null)
  const rightRef = useRef<THREE.Group>(null)
  const fingersL = useRef<(THREE.Mesh | null)[]>([])
  const fingersR = useRef<(THREE.Mesh | null)[]>([])

  useFrame(({ clock }) => {
    const t = clock.elapsedTime

    // Gentle wrist sway while typing
    if (leftRef.current) {
      leftRef.current.rotation.z = Math.sin(t * 2.8) * 0.08
      leftRef.current.position.y = Math.sin(t * 3.5) * 0.006
    }
    if (rightRef.current) {
      rightRef.current.rotation.z = Math.sin(t * 3.1 + 0.6) * 0.08
      rightRef.current.position.y = Math.sin(t * 3.8 + 0.6) * 0.006
    }

    // Per-finger tapping — visible keystrokes
    const hzL = [6.5, 10.8, 8.1, 13.2]
    const hzR = [9.1, 11.5, 7.3, 12.6]
    for (let i = 0; i < 4; i++) {
      const lf = fingersL.current[i]
      if (lf) {
        const tap = Math.max(0, Math.sin(t * hzL[i] + i * 0.9))
        lf.position.y = -tap * 0.012
        lf.rotation.x = tap * 0.6
      }
      const rf = fingersR.current[i]
      if (rf) {
        const tap = Math.max(0, Math.sin(t * hzR[i] + i * 1.2))
        rf.position.y = -tap * 0.012
        rf.rotation.x = tap * 0.6
      }
    }
  })

  const Hand = ({ side, handRef, fingerRefs }: {
    side: 'left' | 'right'
    handRef: React.RefObject<THREE.Group | null>
    fingerRefs: React.MutableRefObject<(THREE.Mesh | null)[]>
  }) => {
    const s = side === 'left' ? -1 : 1
    // Hands positioned on the keyboard deck, spread apart
    const fingerX = [-0.018, -0.006, 0.006, 0.018]

    return (
      <group ref={handRef} position={[s * 0.055, 0.018, 0.01]}>
        {/* Palm — rounded astronaut glove, flat on keyboard */}
        <mesh castShadow>
          <sphereGeometry args={[0.028, 10, 8, 0, Math.PI * 2, 0, Math.PI * 0.55]} />
          <meshStandardMaterial color="#c8c8c8" roughness={0.55} metalness={0.1} />
        </mesh>
        {/* Palm underside */}
        <mesh position={[0, -0.003, 0]} castShadow>
          <boxGeometry args={[0.048, 0.008, 0.035]} />
          <meshStandardMaterial color="#bbb" roughness={0.6} metalness={0.08} />
        </mesh>

        {/* 4 fingers — pointing toward screen (-z) */}
        {fingerX.map((fx, i) => (
          <mesh
            key={i}
            ref={el => { fingerRefs.current[i] = el }}
            position={[fx, 0.0, -0.028]}
            castShadow
          >
            <capsuleGeometry args={[0.005, 0.016, 4, 8]} />
            <meshStandardMaterial color="#b8b8b8" roughness={0.5} metalness={0.12} />
          </mesh>
        ))}

        {/* Thumb — angled outward */}
        <mesh position={[s * 0.03, 0.0, -0.005]} rotation={[0, s * -0.5, s * 0.4]} castShadow>
          <capsuleGeometry args={[0.006, 0.014, 4, 8]} />
          <meshStandardMaterial color="#b8b8b8" roughness={0.5} metalness={0.12} />
        </mesh>

        {/* Wrist cuff ring */}
        <mesh position={[0, 0.005, 0.022]} rotation={[Math.PI / 2, 0, 0]} castShadow>
          <torusGeometry args={[0.022, 0.004, 6, 12]} />
          <meshStandardMaterial color="#888" roughness={0.3} metalness={0.35} />
        </mesh>
      </group>
    )
  }

  return (
    <>
      <Hand side="left" handRef={leftRef} fingerRefs={fingersL} />
      <Hand side="right" handRef={rightRef} fingerRefs={fingersR} />
    </>
  )
}

// ─────────────────────────────────────────────────────────────────────────────
// Procedural cinematic laptop  (red chassis, open lid, code on screen)
// ─────────────────────────────────────────────────────────────────────────────
function Laptop() {
  const screenLightRef = useRef<THREE.PointLight>(null)
  const cursorMeshRef  = useRef<THREE.Mesh>(null)

  useFrame(({ clock }) => {
    const t = clock.elapsedTime
    if (screenLightRef.current) {
      screenLightRef.current.intensity =
        1.1 + Math.sin(t * 5.3) * 0.06 + Math.sin(t * 11.9) * 0.03
    }
    if (cursorMeshRef.current) {
      ;(cursorMeshRef.current.material as THREE.MeshBasicMaterial).opacity =
        Math.sin(t * Math.PI) > 0 ? 0.92 : 0.05
    }
  })

  const bodyMat = (
    <meshPhysicalMaterial
      color="#b91c1c"
      metalness={0.85}
      roughness={0.14}
      clearcoat={1}
      clearcoatRoughness={0.04}
    />
  )

  return (
    <group>
      {/* ── BOTTOM CHASSIS ── */}
      <mesh castShadow receiveShadow>{bodyMat}
        <boxGeometry args={[0.36, 0.015, 0.25]} />
      </mesh>

      {/* Rubber feet */}
      {([ [-0.15,-0.009,-0.1],[0.15,-0.009,-0.1],[-0.15,-0.009,0.1],[0.15,-0.009,0.1] ] as [number,number,number][]).map(([x,y,z],i)=>(
        <mesh key={i} position={[x,y,z]}>
          <cylinderGeometry args={[0.013,0.013,0.004,8]} />
          <meshStandardMaterial color="#0a0a0a" roughness={1} />
        </mesh>
      ))}

      {/* Keyboard deck */}
      <mesh position={[0, 0.009, 0]}>
        <boxGeometry args={[0.33, 0.003, 0.21]} />
        <meshPhysicalMaterial color="#1a0808" roughness={0.78} metalness={0.2} />
      </mesh>

      {/* Key-row hint strips */}
      {([-0.074,-0.028,0.018,0.064,0.110]).map((z:number,i:number)=>(
        <mesh key={i} position={[0, 0.012, z]}>
          <boxGeometry args={[0.28, 0.003, 0.028]} />
          <meshPhysicalMaterial color="#2a0c0c" roughness={0.82} emissive="#200808" emissiveIntensity={0.28} />
        </mesh>
      ))}

      {/* Trackpad */}
      <mesh position={[0, 0.011, 0.088]}>
        <boxGeometry args={[0.1, 0.002, 0.065]} />
        <meshPhysicalMaterial color="#2a0d0d" roughness={0.2} clearcoat={0.9} clearcoatRoughness={0.08} />
      </mesh>

      {/* ── LID — open ~110° ── */}
      <group position={[0, 0.0075, -0.125]} rotation={[-1.18, 0, 0]}>

        {/* Lid shell */}
        <mesh castShadow>{bodyMat}
          <boxGeometry args={[0.36, 0.258, 0.013]} />
        </mesh>

        {/* Inner bezel */}
        <mesh position={[0, 0, 0.0085]}>
          <boxGeometry args={[0.345, 0.246, 0.006]} />
          <meshPhysicalMaterial color="#070304" roughness={0.9} metalness={0.1} />
        </mesh>

        {/* Display panel */}
        <mesh position={[0, 0.003, 0.013]}>
          <boxGeometry args={[0.318, 0.228, 0.001]} />
          <meshPhysicalMaterial
            color="#050d1e"
            emissive="#1a3d82"
            emissiveIntensity={0.42}
            roughness={0.02}
            metalness={0}
          />
        </mesh>

        {/* Syntax-highlighted code lines */}
        {([{y:0.09,w:0.12,x:-0.07,c:'#61dafb'},{y:0.064,w:0.18,x:-0.04,c:'#c3e88d'},
           {y:0.038,w:0.09,x:-0.10,c:'#ff79c6'},{y:0.012,w:0.14,x:-0.06,c:'#bd93f9'},
           {y:-0.014,w:0.16,x:-0.05,c:'#50fa7b'},{y:-0.040,w:0.11,x:-0.08,c:'#f1fa8c'},
           {y:-0.066,w:0.19,x:-0.03,c:'#8be9fd'},{y:-0.092,w:0.13,x:-0.07,c:'#ffb86c'},
        ] as {y:number,w:number,x:number,c:string}[]).map(({y,w,x,c},i)=>(
          <mesh key={i} position={[x,y,0.014]} renderOrder={2}>
            <boxGeometry args={[w,0.007,0.001]} />
            <meshBasicMaterial color={c} transparent opacity={0.88} depthWrite={false} />
          </mesh>
        ))}

        {/* Blinking cursor */}
        <mesh ref={cursorMeshRef} position={[0.058,0.09,0.014]} renderOrder={3}>
          <boxGeometry args={[0.005,0.012,0.001]} />
          <meshBasicMaterial color="#ffffff" transparent opacity={0.9} depthWrite={false} />
        </mesh>

        {/* Rocket sticker */}
        <mesh position={[-0.09,0.042,-0.007]}>
          <boxGeometry args={[0.028,0.038,0.001]} />
          <meshBasicMaterial color="#fafafa" />
        </mesh>
        <mesh position={[-0.09,0.06,-0.007]}>
          <coneGeometry args={[0.013,0.02,6]} />
          <meshBasicMaterial color="#ff4500" />
        </mesh>
        <mesh position={[-0.09,0.035,-0.007]}>
          <boxGeometry args={[0.024,0.014,0.001]} />
          <meshBasicMaterial color="#ef4444" />
        </mesh>

        {/* Lock-icon sticker */}
        <mesh position={[0.06,0.048,-0.007]}>
          <boxGeometry args={[0.025,0.026,0.001]} />
          <meshBasicMaterial color="#4ade80" />
        </mesh>

        {/* Screen-glow light */}
        <pointLight
          ref={screenLightRef}
          position={[0, 0.05, 0.24]}
          intensity={1.1}
          color="#3a7ee8"
          distance={1.6}
          decay={2}
        />
      </group>
    </group>
  )
}

export function Astronaut({ position }: { position: [number, number, number] }) {
  const rootRef = useRef<THREE.Group>(null)
  const hiRef = useRef<THREE.Group>(null)
  const modelMotionRef = useRef<THREE.Group>(null)
  const laptopWrapRef = useRef<THREE.Group>(null)

  const mouseSmooth = useRef({ x: 0, y: 0 })
  const greetPulse = useAppStore((s) => s.greetPulse)
  const waveUntil = useRef(0)

  const astronaut = useGLTF('/models/astronaut.glb') as AstronautGLTF
  const model = useMemo(() => SkeletonUtils.clone(astronaut.scene) as THREE.Group, [astronaut.scene])

  // Play any embedded idle/float animation from the GLB
  const { actions } = useAnimations(astronaut.animations, model)
  useEffect(() => {
    const keys = Object.keys(actions)
    const key = keys.find(k => /idle|float|rest|stand/i.test(k)) ?? keys[0]
    if (key && actions[key]) actions[key]!.reset().setEffectiveWeight(1).fadeIn(0.4).play()
  }, [actions])

  // Material upgrades — cinematic PBR look
  useEffect(() => {
    // ─── Model structure diagnostic ───────────────────────────────────
    const box = new THREE.Box3().setFromObject(model)
    const size = new THREE.Vector3()
    const center = new THREE.Vector3()
    box.getSize(size)
    box.getCenter(center)
    console.log('[Astronaut] bounding box:', {
      min: { x: +box.min.x.toFixed(3), y: +box.min.y.toFixed(3), z: +box.min.z.toFixed(3) },
      max: { x: +box.max.x.toFixed(3), y: +box.max.y.toFixed(3), z: +box.max.z.toFixed(3) },
      size: { x: +size.x.toFixed(3), y: +size.y.toFixed(3), z: +size.z.toFixed(3) },
      center: { x: +center.x.toFixed(3), y: +center.y.toFixed(3), z: +center.z.toFixed(3) },
    })
    const nodes: string[] = []
    model.traverse((obj) => {
      const depth = (() => { let d = 0; let p = obj.parent; while (p) { d++; p = p.parent } return d })()
      const indent = '  '.repeat(depth)
      nodes.push(`${indent}${obj.type} "${obj.name}" children=${obj.children.length}`)
    })
    console.log('[Astronaut] scene graph:\n' + nodes.join('\n'))

    model.traverse((obj) => {
      if (!(obj instanceof THREE.Mesh)) return
      obj.castShadow = true
      obj.receiveShadow = true

      const mat = obj.material
      if (!mat) return
      const materials = Array.isArray(mat) ? mat : [mat]

      materials.forEach((m) => {
        if (!(m instanceof THREE.MeshStandardMaterial || m instanceof THREE.MeshPhysicalMaterial)) return
        const name = `${m.name} ${obj.name}`.toLowerCase()

        const isVisor =
          name.includes('visor') || name.includes('glass') || name.includes('helmet') ||
          m.transparent || m.opacity < 0.99

        if (isVisor) {
          obj.material = new THREE.MeshPhysicalMaterial({
            color: new THREE.Color('#d5a11f'),
            emissive: new THREE.Color('#3b2a08'),
            emissiveIntensity: 0.3,
            metalness: 1, roughness: 0.035,
            transmission: 0.08, thickness: 0.45, ior: 1.52,
            clearcoat: 1, clearcoatRoughness: 0.02,
            envMapIntensity: 2.8,
            map: m.map ?? null, normalMap: m.normalMap ?? null,
          })
          return
        }

        const isMetal = name.includes('metal') || name.includes('chrome') ||
          name.includes('buckle') || name.includes('clasp') || m.metalness > 0.6
        obj.material = new THREE.MeshPhysicalMaterial({
          map: m.map ?? null,
          normalMap: m.normalMap ?? null,
          normalScale: m.normalMap ? new THREE.Vector2(1.4, 1.4) : new THREE.Vector2(1, 1),
          roughnessMap: m.roughnessMap ?? null,
          metalnessMap: m.metalnessMap ?? null,
          aoMap: m.aoMap ?? null,
          color: m.color,
          roughness: isMetal ? Math.min(0.22, m.roughness * 0.55) : Math.min(0.72, m.roughness * 0.78),
          metalness: isMetal ? Math.min(1, m.metalness * 1.35) : Math.min(0.28, m.metalness),
          envMapIntensity: isMetal ? 2.4 : 1.65,
          clearcoat: isMetal ? 0.8 : 0.22,
          clearcoatRoughness: isMetal ? 0.08 : 0.32,
          sheen: 0.08, sheenRoughness: 0.85,
          sheenColor: new THREE.Color(isMetal ? '#ffffff' : '#ddeeff'),
        })
      })
    })
  }, [model])

  useEffect(() => {
    if (greetPulse > 0) waveUntil.current = performance.now() + 2300
  }, [greetPulse])

  const { pointer } = useThree()

  // Animation: zero-gravity floating + laptop typing wobble
  useFrame(({ clock, camera }) => {
    if (!rootRef.current) return
    const t = clock.elapsedTime
    const isWaving = performance.now() < waveUntil.current

    // Smooth mouse for subtle reactivity
    mouseSmooth.current.x += (pointer.x - mouseSmooth.current.x) * 0.02
    mouseSmooth.current.y += (pointer.y - mouseSmooth.current.y) * 0.02

    // ── Zero-gravity floating ──────────────────────────────────────────
    if (modelMotionRef.current) {
      // Visible vertical float bob
      modelMotionRef.current.position.y =
        Math.sin(t * 0.7) * 0.12 +
        Math.sin(t * 1.1) * 0.04

      // Forward lean toward laptop + slow pitch sway
      modelMotionRef.current.rotation.x =
        0.1 + Math.sin(t * 0.4) * 0.03

      // Yaw drift + mouse reactivity
      modelMotionRef.current.rotation.y =
        Math.sin(t * 0.3) * 0.04 +
        mouseSmooth.current.x * 0.05

      // Roll for weightless feel
      modelMotionRef.current.rotation.z =
        Math.sin(t * 0.35) * 0.025

      if (isWaving) {
        modelMotionRef.current.rotation.z += Math.sin(t * 4) * 0.06
      }
    }

    // ── Laptop: at hand level, synced float + typing wobble ────────────
    if (laptopWrapRef.current) {
      // Sync vertical bob with astronaut float
      const baseY = 0.75 + Math.sin(t * 0.7) * 0.12 + Math.sin(t * 1.1) * 0.04
      const baseZ = 0.55 + Math.sin(t * 0.5) * 0.015
      laptopWrapRef.current.position.y += (baseY - laptopWrapRef.current.position.y) * 0.15
      laptopWrapRef.current.position.x += (0 - laptopWrapRef.current.position.x) * 0.15
      laptopWrapRef.current.position.z += (baseZ - laptopWrapRef.current.position.z) * 0.15

      // Visible typing wobble
      const typeWobble =
        Math.sin(t * 7.5) * 0.018 +
        Math.sin(t * 12.3) * 0.008 +
        Math.sin(t * 17.9) * 0.005

      laptopWrapRef.current.rotation.x = -0.25 + typeWobble
      laptopWrapRef.current.rotation.y = Math.sin(t * 0.7) * 0.012
      laptopWrapRef.current.rotation.z = Math.sin(t * 0.55) * 0.006
    }

    // ── Hi bubble ──────────────────────────────────────────────────────
    if (hiRef.current) {
      hiRef.current.visible = isWaving
      hiRef.current.position.set(0.28, 1.52 + Math.sin(t * 8) * 0.02, 0.25)
      hiRef.current.lookAt(camera.position)
    }
  }, 2)

  return (
    <group ref={rootRef} position={position} scale={[1.06, 1.06, 1.06]}>
      <group ref={modelMotionRef}>
        <primitive object={model} />
      </group>

      {/* ── Laptop — at hand level, just past body front ── */}
      <group ref={laptopWrapRef} position={[0.0, 0.75, 0.55]} rotation={[-0.25, 0, 0]} scale={[1.3, 1.3, 1.3]}>
        <Laptop />
        <TypingHands />
      </group>

      <group ref={hiRef} visible={false}>
        <mesh>
          <planeGeometry args={[0.42, 0.2]} />
          <meshPhysicalMaterial color="#0b1220" emissive="#1f2937" emissiveIntensity={0.7} transparent opacity={0.92} />
        </mesh>
        <Text
          position={[0, 0, 0.01]}
          fontSize={0.1}
          color="#fef3c7"
          anchorX="center"
          anchorY="middle"
          fontWeight={700}
        >
          Hi 👋
        </Text>
      </group>

      <ContactShadows
        position={[0, -1.22, 0]}
        opacity={0.58}
        scale={4.2}
        blur={2.3}
        far={2.8}
        resolution={1024}
        color="#080a12"
      />
    </group>
  )
}

── END OLD CHARACTER CODE ── */

// ── Active imports for TechOrbs (kept from original file) ───────────────
import { useEffect, useRef } from 'react'
import { useFrame, useThree } from '@react-three/fiber'
import { Sparkles, useGLTF, useTexture } from '@react-three/drei'
import * as THREE from 'three'

type TechItem = {
  icon: string
  tint: string
  radius: number
  speed: number
  offset: number
  height: number
}

const TECH_ITEMS: TechItem[] = [
  { icon: '/tech-icons/csharp.svg', tint: '#b38dff', radius: 1.55, speed: 0.24, offset: 0.1, height: 0.3 },
  { icon: '/tech-icons/dotnet.svg', tint: '#8ea0ff', radius: 1.75, speed: 0.18, offset: 0.9, height: 0.82 },
  { icon: '/tech-icons/angular.svg', tint: '#ff6a7a', radius: 1.95, speed: 0.14, offset: 1.7, height: 1.12 },
  { icon: '/tech-icons/react.svg', tint: '#66d8ff', radius: 1.85, speed: 0.22, offset: 2.4, height: 0.58 },
  { icon: '/tech-icons/openai.svg', tint: '#b3f7ff', radius: 2.05, speed: 0.12, offset: 3.1, height: 1.35 },
  { icon: '/tech-icons/azure.svg', tint: '#7ab7ff', radius: 1.72, speed: 0.2, offset: 3.7, height: 0.2 },
  { icon: '/tech-icons/sqlserver.svg', tint: '#ff8d69', radius: 1.9, speed: 0.16, offset: 4.3, height: 0.72 },
  { icon: '/tech-icons/redis.svg', tint: '#ff8ea2', radius: 1.65, speed: 0.19, offset: 5.2, height: 1.02 },
  { icon: '/tech-icons/docker.svg', tint: '#84c4ff', radius: 2.0, speed: 0.15, offset: 5.8, height: 0.42 },
  { icon: '/tech-icons/kubernetes.svg', tint: '#95a3ff', radius: 2.12, speed: 0.13, offset: 6.1, height: 1.15 },
  { icon: '/tech-icons/aws.svg', tint: '#ffc26f', radius: 1.82, speed: 0.17, offset: 6.6, height: 1.48 },
]

export function TechOrbs({ center }: { center: [number, number, number] }) {
  const groupRef = useRef<THREE.Group>(null)
  const { camera } = useThree()
  const iconMaps = useTexture(TECH_ITEMS.map((item) => item.icon))

  useEffect(() => {
    iconMaps.forEach((tex) => {
      tex.colorSpace = THREE.SRGBColorSpace
      tex.anisotropy = 8
      tex.needsUpdate = true
    })
  }, [iconMaps])

  useFrame(({ clock }) => {
    if (!groupRef.current) return
    const t = clock.elapsedTime
    const cards = groupRef.current.children

    for (let i = 0; i < TECH_ITEMS.length; i++) {
      const cfg = TECH_ITEMS[i]
      const card = cards[i] as THREE.Group
      if (!card) continue

      const a = t * cfg.speed + cfg.offset
      const x = Math.cos(a) * cfg.radius
      const z = Math.sin(a) * cfg.radius * 0.3
      const y = cfg.height + Math.sin(a * 1.8 + i) * 0.12

      card.position.set(x, y, z)
      card.lookAt(camera.position)
    }
  })

  return (
    <group ref={groupRef} position={center}>
      {TECH_ITEMS.map((item, i) => (
        <group key={item.icon}>
          <mesh renderOrder={1}>
            <circleGeometry args={[0.13, 28]} />
            <meshPhysicalMaterial
              color="#0a1222"
              emissive={item.tint}
              emissiveIntensity={0.33}
              roughness={0.14}
              metalness={0.9}
              clearcoat={1}
              clearcoatRoughness={0.06}
              transparent
              opacity={0.88}
              depthWrite={false}
            />
          </mesh>
          <sprite position={[0, 0, 0.018]} scale={[0.13, 0.13, 0.13]} renderOrder={3}>
            <spriteMaterial map={iconMaps[i]} color="#ffffff" transparent depthWrite={false} depthTest={false} />
          </sprite>
          <mesh position={[0, 0, -0.012]} renderOrder={0}>
            <ringGeometry args={[0.145, 0.162, 28]} />
            <meshBasicMaterial color={item.tint} transparent opacity={0.45} depthWrite={false} />
          </mesh>
        </group>
      ))}

      <Sparkles
        count={14}
        scale={[4.8, 2.6, 3.8]}
        size={0.9}
        speed={0.17}
        color="#9fd0ff"
        opacity={0.18}
      />
    </group>
  )
}

// Old preload disabled — new character preloads from Character.tsx
